# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/crypto-galaxy?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Email (Nodemailer - Gmail App Password recommended)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=noreply@cryptogalaxy.io

# Twilio SMS (optional - falls back to console.log mock if not set)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL (Vercel URL after deploy)
FRONTEND_URL=https://crypto-galaxy.vercel.app

# OTP expiry
OTP_EXPIRES_MINUTES=10

NEWS_API_KEY=your_newsapi_org_key_here
# Get a free key at: https://newsapi.org/register
# Alternatively use: https://cryptonews-api.com (free tier available)
# For NewsAPI, you can specify sources or categories in the code to fetch relevant news.

# Logging
LOG_LEVEL=info
ALPHA_VANTAGE_KEY=your_key_here
# Free at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5 requests/min
# Upgrade for higher limits; paid plans from $50/mo

FINNHUB_KEY=your_key_here
# Free at: https://finnhub.io/register
# Free tier: 60 API calls/min — plenty for fallback
